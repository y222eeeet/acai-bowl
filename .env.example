# acai bowl 환경변수 예시 (복사 후 .env로 저장, 실제 값으로 채우세요)
# 이 파일은 커밋해도 되며, .env는 .gitignore에 있어 커밋되지 않아요.

# === 로컬 크롤러 (scripts/horoscope_crawler.py) ===
OPENAI_API_KEY=sk-your-openai-api-key-here

# === 번역 서버 (server/) - Cloud Run 등에 설정 ===
# OPENAI_API_KEY=sk-your-openai-api-key-here
# HOROSCOPE_APP_SECRET=your-random-secret-for-app-validation
